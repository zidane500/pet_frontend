# ─── API Backend ──────────────────────────────────────────────
# URL de base de l'API Laravel
# En développement local :
VITE_API_URL=http://localhost:8000/api

# En production :
# VITE_API_URL=https://api.animali.tn/api

# ─── Stockage fichiers ────────────────────────────────────────
# URL de base pour les images uploadées
# En développement local :
VITE_STORAGE_URL=http://localhost:8000/storage

# En production :
# VITE_STORAGE_URL=https://api.animali.tn/storage

# ─── Laravel Reverb (WebSocket temps-réel) ────────────────────
# Doit correspondre exactement aux valeurs dans le .env backend

# Clé publique Reverb (REVERB_APP_KEY dans le backend)
VITE_REVERB_APP_KEY=your-reverb-app-key

# Hôte du serveur Reverb
# En développement local :
VITE_REVERB_HOST=127.0.0.1

# En production :
# VITE_REVERB_HOST=api.animali.tn

# Port du serveur Reverb
VITE_REVERB_PORT=8090

# Schéma de connexion
# En développement local :
VITE_REVERB_SCHEME=http

# En production (avec SSL) :
# VITE_REVERB_SCHEME=https

# ─── Application ──────────────────────────────────────────────
# Nom affiché dans les balises meta
VITE_APP_NAME=Animali.tn

# Mode de l'application (development / production)
NODE_ENV=development